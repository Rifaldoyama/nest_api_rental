{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": ".",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,

    "sourceMap": true,
    "skipLibCheck": true,

    "baseUrl": ".",

    "paths": {
      "src/*": ["src/*"],
      "prisma/*": ["prisma/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}